// PayLite — Prisma Schema
// PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User (owner account, maps to Supabase Auth) ───────────────────────────

model User {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique
  name        String
  companyName String   @default("My Company")
  createdAt   DateTime @default(now())

  employees   Employee[]
  payrollRuns PayrollRun[]

  @@map("users")
}

// ─── Employee ───────────────────────────────────────────────────────────────

enum EmployeeStatus {
  active
  inactive
}

model Employee {
  id           String         @id @default(uuid()) @db.Uuid
  userId       String         @db.Uuid
  name         String
  role         String
  basicSalary  Decimal        @db.Decimal(12, 2)
  hra          Decimal        @db.Decimal(12, 2)
  pfEnabled    Boolean        @default(true)
  esiEnabled   Boolean        @default(true)
  joiningDate  DateTime
  status       EmployeeStatus @default(active)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendance   AttendanceLog[]
  bonuses      BonusEvent[]
  payslips     Payslip[]
  scans        AttendanceScan[]

  @@map("employees")
}

model AttendanceScan {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @db.Uuid
  scanTime   DateTime @default(now())
  type       String   // "IN" or "OUT"
  latitude   Float?
  longitude  Float?
  ipAddress  String?

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("attendance_scans")
}

// ─── Attendance Log ─────────────────────────────────────────────────────────

model AttendanceLog {
  id             String   @id @default(uuid()) @db.Uuid
  employeeId     String   @db.Uuid
  month          Int
  year           Int
  presentDays    Int      @default(0)
  paidLeaveDays  Int      @default(0)
  unpaidLeaveDays Int     @default(0)
  overtimeHours  Decimal  @default(0) @db.Decimal(8, 2)

  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@map("attendance_logs")
}

// ─── Bonus Event ────────────────────────────────────────────────────────────

model BonusEvent {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @db.Uuid
  month      Int
  year       Int
  label      String
  amount     Decimal  @db.Decimal(12, 2)

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("bonus_events")
}

// ─── Payroll Run ────────────────────────────────────────────────────────────

enum PayrollStatus {
  draft
  processed
}

model PayrollRun {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @db.Uuid
  month       Int
  year        Int
  status      PayrollStatus @default(draft)
  runAt       DateTime      @default(now())
  totalPayout Decimal       @default(0) @db.Decimal(14, 2)

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payslips    Payslip[]

  @@unique([userId, month, year])
  @@map("payroll_runs")
}

// ─── Payslip ────────────────────────────────────────────────────────────────

model Payslip {
  id           String     @id @default(uuid()) @db.Uuid
  payrollRunId String     @db.Uuid
  employeeId   String     @db.Uuid
  breakdown    Json
  netPay       Decimal    @db.Decimal(12, 2)
  generatedAt  DateTime   @default(now())

  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
  @@map("payslips")
}
